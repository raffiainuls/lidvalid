# Set to "production" on the VPS to enable strict startup checks (refuses to
# boot without LIDVALID_SECRET_KEY / LIDVALID_ADMIN_USERNAME / LIDVALID_ADMIN_PASSWORD).
LIDVALID_ENV=development

# Required in production (see app/security.py). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Back this up somewhere OTHER than the VPS -- losing it makes every stored
# connection secret permanently undecryptable, and invalidates every session.
LIDVALID_SECRET_KEY=

# Required in production for first-run bootstrap (see app/main.py). Ignored
# after the first user row already exists in the database.
LIDVALID_ADMIN_USERNAME=
LIDVALID_ADMIN_PASSWORD=

# Postgres service (see docker-compose.yml's `postgres` service). Generate a
# strong password with e.g. `openssl rand -base64 24` -- don't reuse
# LIDVALID_SECRET_KEY or any other secret for this.
POSTGRES_USER=lidvalid
POSTGRES_PASSWORD=
POSTGRES_DB=lidvalid

# Points the app at the `postgres` service instead of the local SQLite file.
# `env_file:` values are literal -- Compose does NOT expand ${...} refs to
# other keys in this same file, so repeat the actual POSTGRES_USER/PASSWORD/DB
# values above by hand rather than referencing them here.
# Leave unset to fall back to SQLite under data/ (see app/database.py).
DATABASE_URL=postgresql+psycopg://lidvalid:<same-as-POSTGRES_PASSWORD-above>@postgres:5432/lidvalid

# Required for Caddy (see Caddyfile) -- kept out of the tracked Caddyfile so
# the real VPS IP/domain never ends up in git history.
# Your public IP + ".sslip.io" (no real domain yet), or a real domain once
# you have one -- e.g. 203.0.113.10.sslip.io
CADDY_DOMAIN=
